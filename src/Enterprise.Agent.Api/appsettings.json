{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Ai": {
    "Provider": "",
    "EmbeddingDimensions": 1536,
    "OpenAI": {
      "ApiKey": "",
      "ChatModel": "gpt-4o-mini",
      "EmbeddingModel": "text-embedding-3-small"
    },
    "AzureOpenAI": {
      "Endpoint": "",
      "ApiKey": "",
      "ChatDeployment": "gpt-4o-mini",
      "EmbeddingDeployment": "text-embedding-3-small",
      "ApiVersion": "2024-10-21"
    }
  },
  "Orchestrator": {
    "MaxRetries": 2,
    "RetryDelay": "00:00:00.500",
    "StepTimeout": "00:02:00",
    "MaxDegreeOfParallelism": 4,
    "StopOnFirstFailure": true
  },
  "Planner": {
    "UseLlmPlanner": true,
    "PromptName": "planner",
    "FallbackAgent": "ResearchAgent"
  },
  "AgentDefaults": {
    "Temperature": 0.2,
    "TopP": 1.0,
    "MaxTokens": 1024
  },
  "Rag": {
    "DefaultCollection": "knowledge",
    "ChunkSize": 1200,
    "ChunkOverlap": 200,
    "TopK": 5,
    "MinScore": 0.0
  },
  "VectorStore": {
    "Provider": "Postgres",
    "Postgres": {
      "ConnectionString": "Host=localhost;Port=5432;Database=enterprise_agent;Username=postgres;Password=postgres",
      "TablePrefix": "vec_"
    },
    "AzureAiSearch": {
      "Endpoint": "",
      "ApiKey": "",
      "ApiVersion": "2024-07-01"
    }
  },
  "Memory": {
    "RedisConnectionString": "localhost:6379",
    "KeyPrefix": "eaa",
    "ConversationTtlMinutes": 240,
    "SemanticCollection": "memory",
    "EmbeddingDimensions": 1536
  },
  "SqlAgent": {
    "ConnectionString": "",
    "DefaultMaxRows": 100,
    "StaticSchema": "",
    "CommandTimeoutSeconds": 30
  },
  "Smtp": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "From": "no-reply@enterprise-agent.local"
  },
  "Tools": {
    "Search": { "Endpoint": "", "ApiKey": "", "MaxResults": 5 },
    "Weather": { "EndpointFormat": "https://wttr.in/{0}?format=j1" },
    "RestApi": { "AllowedHosts": [], "TimeoutSeconds": 30 },
    "File": { "MaxReadBytes": 1048576 }
  },
  "Persistence": {
    "ConnectionString": "Server=localhost;Database=EnterpriseAgent;Trusted_Connection=True;TrustServerCertificate=True;",
    "AutoMigrate": true
  },
  "Jwt": {
    "Issuer": "enterprise-agent",
    "Audience": "enterprise-agent-clients",
    "SigningKey": "",
    "ExpiryMinutes": 60
  },
  "ApiKeys": {
    "Keys": {
      "dev-local-api-key-change-me": "local-development"
    }
  }
}
