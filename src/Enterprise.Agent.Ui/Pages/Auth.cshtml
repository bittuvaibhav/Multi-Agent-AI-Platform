@page
@model AuthModel
@{
    ViewData["Title"] = "Auth / Token";
}

<div class="mb-4 rounded-lg border border-sky-500/30 bg-sky-500/10 p-3 text-xs text-sky-200">
    Issue a development JWT from <code>/api/auth/token</code>. Paste it into the Scalar "Authorize" dialog to call secured endpoints as a user. The UI itself authenticates to the API with an API key configured server-side.
</div>

<section class="card mx-auto max-w-xl rounded-xl p-5">
    <form method="post" class="space-y-3">
        <div>
            <label class="mb-1 block text-xs uppercase tracking-wide text-slate-400">Subject</label>
            <input name="Subject" value="@Model.Subject"
                   class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm focus:border-violet-500 focus:outline-none" />
        </div>
        <div>
            <label class="mb-1 block text-xs uppercase tracking-wide text-slate-400">Roles (comma-separated)</label>
            <input name="Roles" value="@Model.Roles"
                   class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm focus:border-violet-500 focus:outline-none" />
        </div>
        <button class="rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium hover:bg-violet-500">Issue token</button>
    </form>

    @if (Model.Error is not null)
    {
        <div class="mt-4 rounded-lg border border-rose-500/40 bg-rose-500/10 p-4 text-sm text-rose-200">@Model.Error</div>
    }
    @if (Model.Token is not null)
    {
        <div class="mt-4">
            <div class="text-xs uppercase tracking-wide text-slate-400">Access token (expires @Model.Token.ExpiresAt.ToString("u"))</div>
            <textarea readonly rows="5"
                      class="mt-2 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 font-mono text-xs text-emerald-300">@Model.Token.AccessToken</textarea>
        </div>
    }
</section>
