@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
    (string Icon, string Title, string Desc, string Page)[] tiles =
    [
        ("💬", "Chat", "Talk to the multi-agent system in real time", "/Chat"),
        ("🤖", "Agents", "Inspect, plan and run the 12 agents", "/Agents"),
        ("📚", "Knowledge (RAG)", "Ingest documents and ask grounded questions", "/Rag"),
        ("🗄️", "SQL Agent", "Natural-language, read-only database queries", "/Sql"),
        ("🧠", "Memory", "Conversation and semantic memory", "/Memory"),
        ("🛠️", "Tools", "Browse and invoke Semantic Kernel plugins", "/Tools"),
    ];
}

@if (Model.Error is not null)
{
    <div class="mb-6 rounded-lg border border-amber-500/40 bg-amber-500/10 p-4 text-sm text-amber-200">
        <strong>API unreachable.</strong> @Model.Error
        <div class="mt-1 text-amber-300/80">Start the API (<code>dotnet run --project src/Enterprise.Agent.Api</code>) and check the <code>Api:BaseUrl</code> setting.</div>
    </div>
}

<div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="card rounded-xl p-5">
        <div class="text-xs uppercase tracking-wide text-slate-400">API status</div>
        <div class="mt-2 flex items-center gap-2 text-2xl font-semibold">
            <span class="h-3 w-3 rounded-full @(Model.ApiOnline ? "bg-emerald-400" : "bg-rose-500")"></span>
            @(Model.ApiOnline ? Model.HealthStatus : "Offline")
        </div>
    </div>
    <div class="card rounded-xl p-5">
        <div class="text-xs uppercase tracking-wide text-slate-400">Registered agents</div>
        <div class="mt-2 text-2xl font-semibold">@Model.AgentCount</div>
    </div>
    <div class="card rounded-xl p-5">
        <div class="text-xs uppercase tracking-wide text-slate-400">API reference</div>
        <a class="mt-2 inline-block text-2xl font-semibold text-violet-300 hover:underline" href="@Model.ScalarUrl" target="_blank">Scalar ↗</a>
    </div>
</div>

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    @foreach (var t in tiles)
    {
        <a asp-page="@t.Page" class="card group rounded-xl p-5 transition hover:ring-1 hover:ring-violet-500/40">
            <div class="text-3xl">@t.Icon</div>
            <div class="mt-3 text-lg font-semibold group-hover:text-violet-300">@t.Title</div>
            <div class="mt-1 text-sm text-slate-400">@t.Desc</div>
        </a>
    }
</div>
