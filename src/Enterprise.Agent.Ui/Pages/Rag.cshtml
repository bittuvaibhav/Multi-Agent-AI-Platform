@page
@model RagModel
@{
    ViewData["Title"] = "Knowledge (RAG)";
}

@if (Model.Error is not null)
{
    <div class="mb-6 rounded-lg border border-rose-500/40 bg-rose-500/10 p-4 text-sm text-rose-200">@Model.Error</div>
}
@if (Model.Notice is not null)
{
    <div class="mb-6 rounded-lg border border-emerald-500/40 bg-emerald-500/10 p-4 text-sm text-emerald-200">@Model.Notice</div>
}

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <section class="card rounded-xl p-5">
        <h2 class="mb-3 text-base font-semibold">Ask the knowledge base</h2>
        <form method="post" class="space-y-3">
            <textarea name="Query" rows="2" placeholder="Ask a question grounded in the ingested documents…"
                      class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm focus:border-violet-500 focus:outline-none">@Model.Query</textarea>
            <div class="flex flex-wrap gap-3">
                <input name="Collection" value="@Model.Collection" placeholder="Collection (optional)"
                       class="flex-1 rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm focus:border-violet-500 focus:outline-none" />
                <input name="TopK" type="number" min="1" max="50" value="@Model.TopK"
                       class="w-24 rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm focus:border-violet-500 focus:outline-none" />
            </div>
            <div class="flex gap-2">
                <button asp-page-handler="Answer" class="rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium hover:bg-violet-500">Answer</button>
                <button asp-page-handler="Query" class="rounded-lg border border-slate-600 px-4 py-2 text-sm font-medium hover:bg-slate-800">Retrieve chunks</button>
            </div>
        </form>

        @if (Model.Answer is not null)
        {
            <div class="mt-4 rounded-lg border border-slate-700 bg-slate-900 p-4">
                <div class="text-xs uppercase tracking-wide text-slate-400">Answer</div>
                <pre class="mt-2 text-sm text-slate-200">@Model.Answer</pre>
            </div>
        }
        @if (Model.Context is not null)
        {
            <div class="mt-4 space-y-2">
                <div class="text-xs uppercase tracking-wide text-slate-400">Retrieved (@Model.Context.Chunks.Count)</div>
                @foreach (var c in Model.Context.Chunks)
                {
                    <div class="rounded-lg border border-slate-700 bg-slate-900 p-3">
                        <div class="mb-1 flex items-center justify-between text-xs text-slate-500">
                            <span>[@c.DocumentId]</span><span>score @c.Score.ToString("0.000")</span>
                        </div>
                        <div class="text-sm text-slate-300">@(c.Text.Length > 400 ? c.Text[..400] + "…" : c.Text)</div>
                    </div>
                }
            </div>
        }
    </section>

    <section class="card rounded-xl p-5">
        <h2 class="mb-3 text-base font-semibold">Ingest a document</h2>
        <form method="post" asp-page-handler="Ingest" enctype="multipart/form-data" class="space-y-3">
            <input type="file" name="Upload" accept=".pdf,.docx,.doc,.md,.markdown,.txt"
                   class="block w-full text-sm text-slate-300 file:mr-3 file:rounded-lg file:border-0 file:bg-violet-600 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-violet-500" />
            <input name="Collection" value="@Model.Collection" placeholder="Collection (optional)"
                   class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm focus:border-violet-500 focus:outline-none" />
            <button class="rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium hover:bg-violet-500">Upload &amp; ingest</button>
            <p class="text-xs text-slate-500">Supports PDF, Word (.docx), Markdown and text.</p>
        </form>

        <h3 class="mb-2 mt-6 text-sm font-semibold text-slate-300">Ingested documents (@Model.Documents.Count)</h3>
        <div class="space-y-2">
            @foreach (var d in Model.Documents)
            {
                <div class="flex items-center justify-between rounded-lg border border-slate-800 bg-slate-900 px-3 py-2 text-sm">
                    <span class="truncate">@d.FileName</span>
                    <span class="ml-2 shrink-0 text-xs text-slate-500">@d.Collection · @d.ChunkCount chunks</span>
                </div>
            }
            @if (Model.Documents.Count == 0)
            {
                <div class="text-sm text-slate-500">No documents ingested yet.</div>
            }
        </div>
    </section>
</div>
