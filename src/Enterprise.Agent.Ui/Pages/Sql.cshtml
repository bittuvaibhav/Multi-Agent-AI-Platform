@page
@model SqlModel
@{
    ViewData["Title"] = "SQL Agent";
}

<div class="mb-4 rounded-lg border border-sky-500/30 bg-sky-500/10 p-3 text-xs text-sky-200">
    The SQL agent generates a <strong>read-only</strong> SELECT, validates it against the safety policy, executes it and summarises the result. Destructive statements are blocked.
</div>

<section class="card rounded-xl p-5">
    <form method="post" class="space-y-3">
        <textarea name="Question" rows="2" placeholder="e.g. How many active customers signed up last month?"
                  class="w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm focus:border-violet-500 focus:outline-none">@Model.Question</textarea>
        <div class="flex flex-wrap gap-3">
            <input name="DataSource" value="@Model.DataSource" placeholder="Data source (optional)"
                   class="flex-1 rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm focus:border-violet-500 focus:outline-none" />
            <input name="MaxRows" type="number" min="1" max="10000" value="@Model.MaxRows"
                   class="w-28 rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm focus:border-violet-500 focus:outline-none" />
            <button class="rounded-lg bg-violet-600 px-4 py-2 text-sm font-medium hover:bg-violet-500">Ask</button>
        </div>
    </form>
</section>

@if (Model.Error is not null)
{
    <div class="mt-6 rounded-lg border border-rose-500/40 bg-rose-500/10 p-4 text-sm text-rose-200">@Model.Error</div>
}

@if (Model.Result is not null)
{
    var r = Model.Result;
    <div class="mt-6 space-y-4">
        @if (r.ValidationViolations.Count > 0)
        {
            <div class="rounded-lg border border-amber-500/40 bg-amber-500/10 p-4 text-sm text-amber-200">
                <strong>Blocked by safety policy:</strong> @string.Join("; ", r.ValidationViolations)
            </div>
        }
        <div class="card rounded-xl p-5">
            <div class="text-xs uppercase tracking-wide text-slate-400">Summary</div>
            <pre class="mt-2 text-sm text-slate-200">@r.Summary</pre>
        </div>
        <div class="card rounded-xl p-5">
            <div class="text-xs uppercase tracking-wide text-slate-400">Generated SQL</div>
            <pre class="mt-2 rounded bg-slate-950 p-3 text-sm text-emerald-300">@r.GeneratedSql</pre>
        </div>
        @if (r.Data is not null && r.Data.Rows.Count > 0)
        {
            <div class="card overflow-x-auto rounded-xl p-5">
                <div class="mb-2 text-xs uppercase tracking-wide text-slate-400">Result (@r.Data.RowCount rows)</div>
                <table class="w-full text-left text-sm">
                    <thead>
                        <tr class="border-b border-slate-700 text-slate-400">
                            @foreach (var col in r.Data.Columns)
                            {
                                <th class="px-3 py-2 font-medium">@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in r.Data.Rows)
                        {
                            <tr class="border-b border-slate-800">
                                @foreach (var cell in row)
                                {
                                    <td class="px-3 py-2 text-slate-200">@cell</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
