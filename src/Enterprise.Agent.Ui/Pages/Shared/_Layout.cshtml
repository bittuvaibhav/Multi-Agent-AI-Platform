@{
    string? current = ViewContext.RouteData.Values["page"] as string;
    string NavClass(string page) =>
        string.Equals(current, page, StringComparison.OrdinalIgnoreCase)
            ? "flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium bg-violet-600/20 text-violet-300 ring-1 ring-violet-500/30"
            : "flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-300 hover:bg-slate-800 hover:text-white transition";
}
<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Enterprise Agent</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { darkMode: 'class', theme: { extend: { fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] } } } };
    </script>
    <style>
        body { background: #0b1120; }
        .card { background: #0f172a; border: 1px solid #1e293b; }
        pre { white-space: pre-wrap; word-break: break-word; }
    </style>
</head>
<body class="min-h-screen text-slate-100 font-sans">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="w-64 shrink-0 border-r border-slate-800 bg-slate-950/60 p-4 hidden md:flex md:flex-col">
            <div class="mb-6 flex items-center gap-2 px-2">
                <div class="grid h-9 w-9 place-items-center rounded-lg bg-violet-600 text-lg font-bold">EA</div>
                <div>
                    <div class="text-sm font-semibold leading-tight">Enterprise Agent</div>
                    <div class="text-xs text-slate-400">Multi-Agent Platform</div>
                </div>
            </div>
            <nav class="flex flex-1 flex-col gap-1">
                <a class="@NavClass("/Index")" asp-page="/Index">🏠 <span>Dashboard</span></a>
                <a class="@NavClass("/Chat")" asp-page="/Chat">💬 <span>Chat</span></a>
                <a class="@NavClass("/Agents")" asp-page="/Agents">🤖 <span>Agents</span></a>
                <a class="@NavClass("/Rag")" asp-page="/Rag">📚 <span>Knowledge (RAG)</span></a>
                <a class="@NavClass("/Sql")" asp-page="/Sql">🗄️ <span>SQL Agent</span></a>
                <a class="@NavClass("/Memory")" asp-page="/Memory">🧠 <span>Memory</span></a>
                <a class="@NavClass("/Tools")" asp-page="/Tools">🛠️ <span>Tools</span></a>
                <a class="@NavClass("/Auth")" asp-page="/Auth">🔑 <span>Auth / Token</span></a>
            </nav>
            <div class="mt-4 border-t border-slate-800 pt-3 text-xs text-slate-500">
                .NET 10 · Semantic Kernel
            </div>
        </aside>

        <!-- Main -->
        <div class="flex min-w-0 flex-1 flex-col">
            <header class="flex items-center justify-between border-b border-slate-800 px-6 py-4">
                <h1 class="text-lg font-semibold">@ViewData["Title"]</h1>
                <div class="flex items-center gap-2 text-xs text-slate-400">
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-800 px-3 py-1">
                        <span class="h-2 w-2 rounded-full bg-emerald-400"></span> Connected to API
                    </span>
                </div>
            </header>
            <main class="min-w-0 flex-1 p-6">
                @RenderBody()
            </main>
        </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
